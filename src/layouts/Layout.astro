---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/icono.webp" />
    <link rel="icon" href="/icono.webp" />
    <meta name="generator" content={Astro.generator} />
    <title>Creamos tu Web — Ecosistema de Ventas Todo en Uno</title>

    <!-- Google Fonts: preconnect first, then non-blocking stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      />
    </noscript>

    <!-- SEO -->
    <meta
      name="description"
      content="Construimos tu Ecosistema de Ventas Todo en Uno. Embudos, CRM y automatizaciones de WhatsApp listas para operar, sin que toques una sola línea de código."
    />
    <link rel="canonical" href="https://landing.creamostuweb.co/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://landing.creamostuweb.co/" />
    <meta
      property="og:title"
      content="Creamos tu Web — Ecosistema de Ventas Todo en Uno"
    />
