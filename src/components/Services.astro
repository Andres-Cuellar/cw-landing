<style>
.pricing-section {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 100px 24px;
        font-family: "Plus Jakarta Sans", sans-serif;
        background: var(--clr-bg);
    }

    .container {
        max-width: 1160px;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 56px;
    }

    /* ── Header ── */
    .section-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 16px;
    }

    .badge {
        display: inline-block;
        color: var(--clr-accent);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        padding: 6px 14px;
        border: 1px solid var(--clr-accent-border);
        background: var(--clr-accent-bg);
        border-radius: 6px;
        text-transform: uppercase;
    }

    .title {
        color: var(--clr-featured);
        font-size: clamp(32px, 4vw, 48px);
        font-weight: 800;
        line-height: 1.15;
        margin: 0;
        letter-spacing: -0.025em;
    }

    .subtitle {
        color: var(--clr-text-4);
        font-size: 16px;
        font-weight: 400;
        margin: 0;
    }

    /* ── Grid ── */
    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        align-items: start;
    }

    /* ── Card base ── */
    .pricing-card {
        border-radius: 20px;
        border: 1px solid var(--clr-border);
        background: var(--clr-bg);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative;
    }

    /* ── Featured card ── */
    .featured-card {
        background: var(--clr-featured);
        border-color: transparent;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
        transform: translateY(-20px);
    }

    /* Rainbow glow bar at the top */
    .rainbow-glow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(
            90deg,
            #ff6b6b,
            #ffa500,
            #ffe066,
            #6bff6b,
            #66d9ff,
            #6b8cff,
            #c966ff,
            #ff6bcc
        );
        border-radius: 20px 20px 0 0;
    }

    /* Soft colour halo above featured card */
    .featured-card::before {
        content: "";
        position: absolute;
        top: -28px;
        left: 50%;
        transform: translateX(-50%);
        width: 85%;
        height: 56px;
        background: linear-gradient(
            90deg,
            rgba(255, 107, 107, 0.45),
            rgba(107, 140, 255, 0.55),
            rgba(201, 102, 255, 0.45)
        );
        filter: blur(26px);
        border-radius: 50%;
        z-index: -1;
    }

    /* ── Card Header ── */
    .card-header {
        padding: 32px 32px 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .plan-label {
        font-size: 18px;
        font-weight: 800;
        color: var(--clr-text);
        letter-spacing: -0.01em;
    }

    .featured-card .plan-label {
        color: var(--clr-bg);
    }

    .plan-tagline {
        font-size: 13px;
        color: var(--clr-text-4);
        font-style: italic;
        margin: 0;
    }

    .featured-card .plan-tagline {
        color: var(--clr-text-5);
    }

    .featured-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--clr-accent);
        color: var(--clr-bg);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
        padding: 4px 10px;
        border-radius: 20px;
        width: fit-content;
        margin-bottom: 4px;
    }

    /* ── Price ── */
    .price-row {
        margin: 8px 0 4px;
    }

    .price {
        font-size: 44px;
        font-weight: 800;
        color: var(--clr-text);
        letter-spacing: -0.03em;
        line-height: 1;
    }

    .price-white {
        color: var(--clr-bg);
    }

    /* ── Description ── */
    .plan-desc {
        font-size: 14px;
        color: var(--clr-text-3);
        line-height: 1.65;
        margin: 4px 0 0;
    }

    .plan-desc-light {
        color: var(--clr-text-5);
    }

    /* ── CTA Buttons ── */
    .cta-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-outline,
    .btn-solid,
    .btn-white-outline,
    .btn-white-solid {
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-size: 14px;
        font-weight: 700;
        padding: 13px 20px;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        text-align: center;
    }

    .btn-outline {
        background: transparent;
        color: var(--clr-text);
        border: 2px solid var(--clr-border-md);
    }
    .btn-outline:hover {
        border-color: var(--clr-text);
    }

    .btn-solid {
        background: var(--clr-text);
        color: var(--clr-bg);
        border: 2px solid var(--clr-text);
    }
    .btn-solid:hover {
        background: var(--clr-ink-soft);
        border-color: var(--clr-ink-soft);
    }

    .btn-white-outline {
        background: transparent;
        color: var(--clr-bg);
        border: 2px solid rgba(255, 255, 255, 0.3);
    }
    .btn-white-outline:hover {
        border-color: rgba(255, 255, 255, 0.7);
    }

    .btn-white-solid {
        background: var(--clr-bg);
        color: var(--clr-text);
        border: 2px solid var(--clr-bg);
    }
    .btn-white-solid:hover {
        background: var(--clr-bg-muted);
    }

    /* ── Features block ── */
    .features-block {
        padding: 24px 32px 32px;
        border-top: 1px solid var(--clr-border);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .featured-card .features-block {
        border-top-color: rgba(255, 255, 255, 0.1);
    }

    .features-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--clr-text);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .features-title-light {
        color: var(--clr-bg);
    }

    .features-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .features-list li {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 14px;
        color: var(--clr-text-2);
        line-height: 1.5;
    }

    .features-list-light li {
        color: var(--clr-border-md);
    }

    .check-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        width: 18px;
        height: 18px;
        background: var(--clr-bg-muted);
        color: var(--clr-text);
        font-size: 10px;
        font-weight: 900;
        border-radius: 50%;
        margin-top: 1px;
        flex-shrink: 0;
    }

    .check-blue {
        background: var(--clr-accent);
        color: var(--clr-bg);
    }

    .ideal-for {
        font-size: 13px;
        color: var(--clr-text-3);
        line-height: 1.6;
        margin: 0;
        padding: 14px;
        background: var(--clr-bg-subtle);
        border-radius: 10px;
        border: 1px solid var(--clr-border);
    }

    .ideal-for-light {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.1);
        color: var(--clr-text-4);
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
        .pricing-grid {
            grid-template-columns: 1fr;
            max-width: 520px;
            margin: 0 auto;
        }

        .featured-card {
            transform: none;
            order: -1;
        }
    }

    @media (max-width: 480px) {
        .pricing-section {
            padding: 60px 16px;
        }

        .card-header,
        .features-block {
            padding-left: 20px;
            padding-right: 20px;
        }

        .price {
            font-size: 36px;
        }
    }
</style>
